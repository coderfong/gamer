NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Phase 2 — security stack
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
CRON_SECRET=

# QR-only play gating. Set to a long random secret in production to require the
# signed token (embedded in each game's QR/share link) for /play/<slug>. Leave
# blank to keep games openly accessible (dev default).
PLAY_QR_SECRET=

# Hidden admin login. Set in production to disable public signup and hide the
# /login page (404) from the public. Unlock the login form once per browser via
# /login?key=<this value>. Leave blank in dev to keep auth pages open.
ADMIN_LOGIN_KEY=

# Phase 2 — Upstash rate limiting (leave blank for dev: limits become no-ops)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Phase 3 — Resend (welcome email; no-op fallback if unset)
RESEND_API_KEY=
RESEND_FROM="gamer <onboarding@resend.dev>"
ADMIN_NOTIFICATION_EMAIL=
